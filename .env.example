# --- Core ---
SITE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:devpass@localhost:5432/rise_up_together

# --- Auth.js ---
AUTH_SECRET=                    # generate with: openssl rand -base64 32
AUTH_TRUST_HOST=true

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=noreply@riseuptogether.co.uk
ADMIN_INBOX_EMAIL=

# --- Captcha (hCaptcha) ---
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# --- Image uploads ---
# Local dev: ./.uploads | Railway: /data/uploads
UPLOAD_DIR=./.uploads
MAX_UPLOAD_MB=5

# --- Seed admin (read by prisma/seed.ts) ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
